generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum ResourceType {
  COURSE
  SUMMARY
  EXERCISE
  CORRECTION
  METHOD
  REPORT
}

enum DeckOrigin {
  MANUAL
  TEACHER
  AI
}

enum FlashcardStatus {
  NEW
  LEARNING
  REVIEW
  LAPSED
}

enum FlashcardRating {
  AGAIN
  HARD
  MEDIUM
  EASY
  VERY_EASY
}

enum TaskType {
  HOMEWORK
  REVISION
  ESSAY
  FLASHCARDS
  EXERCISE
}

enum SessionType {
  FLASHCARDS_REVIEW
  CHAPTER_REVISION
  EXERCISE_TRAINING
  ESSAY_PRACTICE
  CORRECTION_REVIEW
}

enum SessionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum WeakPointStatus {
  ACTIVE
  IMPROVING
  RESOLVED
}

enum EssayStatus {
  SUBMITTED
  AI_REVIEWED
  TEACHER_REVIEWED
}

enum ReviewerType {
  AI
  TEACHER
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String?
  firstName         String
  lastName          String
  role              UserRole
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  memberships       ClassMembership[]
  studentProfile    StudentProfile?
  uploadedResources Resource[]
  decks             FlashcardDeck[]
  reviews           FlashcardReview[]
  flashcardStates   FlashcardState[]
  tasks             Task[]
  studySessions     StudySession[]
  weakPoints        WeakPoint[]
  essays            Essay[]            @relation("StudentEssays")
  assignedEssays    Essay[]            @relation("TeacherEssays")
  rubrics           GradingRubric[]
  resourceAiOutputs ResourceAIOutput[]
  aiGenerations     AIGeneration[]
  grades            StudentGrade[]
  flashcardShares   FlashcardShare[]
  newsSelections    NewsSelection[]
  passwordResetTokens PasswordResetToken[]
}

model Class {
  id          String            @id @default(cuid())
  name        String
  yearLabel   String
  track       String
  accessCode  String            @unique
  createdAt   DateTime          @default(now())
  memberships ClassMembership[]
  students    StudentProfile[]
  resources   Resource[]
  decks       FlashcardDeck[]
}

model ClassMembership {
  id          String   @id @default(cuid())
  userId      String
  classId     String
  roleInClass String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
}

model StudentProfile {
  id                String                    @id @default(cuid())
  userId            String                    @unique
  classId           String
  prepYear          Int
  targetExams       Json
  weeklyGoalHours   Int?
  energyProfile     Json?
  strengthsText     String?
  weaknessesText    String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  class             Class                     @relation(fields: [classId], references: [id], onDelete: Cascade)
  availabilitySlots StudentAvailabilitySlot[]
}

model StudentAvailabilitySlot {
  id        String         @id @default(cuid())
  studentId String
  dayOfWeek Int
  startTime String
  endTime   String
  slotType  String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Subject {
  id         String          @id @default(cuid())
  code       String          @unique
  name       String
  chapters   Chapter[]
  resources  Resource[]
  decks      FlashcardDeck[]
  tasks      Task[]
  sessions   StudySession[]
  weakPoints WeakPoint[]
  essays     Essay[]
  rubrics    GradingRubric[]
  grades     StudentGrade[]
}

model Chapter {
  id         String          @id @default(cuid())
  subjectId  String
  name       String
  slug       String          @unique
  examTags   Json?
  subject    Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  resources  Resource[]
  decks      FlashcardDeck[]
  tasks      Task[]
  sessions   StudySession[]
  weakPoints WeakPoint[]
  essays     Essay[]
}

model Resource {
  id                 String             @id @default(cuid())
  uploaderId         String
  classId            String?
  subjectId          String
  chapterId          String?
  title              String
  description        String?
  resourceType       ResourceType
  storageKey         String
  mimeType           String
  sourceKind         String
  isAiActionsEnabled Boolean            @default(true)
  createdAt          DateTime           @default(now())
  uploader           User               @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  class              Class?             @relation(fields: [classId], references: [id], onDelete: SetNull)
  subject            Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter            Chapter?           @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  accessRules        ResourceAccess[]
  aiOutputs          ResourceAIOutput[]
  sourceDecks        FlashcardDeck[]
}

model ResourceAccess {
  id         String   @id @default(cuid())
  resourceId String
  userId     String?
  classId    String?
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model ResourceAIOutput {
  id          String   @id @default(cuid())
  resourceId  String
  userId      String
  outputType  String
  contentJson Json
  createdAt   DateTime @default(now())
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FlashcardDeck {
  id               String      @id @default(cuid())
  ownerUserId      String
  classId          String?
  subjectId        String
  chapterId        String?
  parentDeckId     String?
  sourceResourceId String?
  title            String
  description      String?
  createdByType    DeckOrigin
  createdAt        DateTime    @default(now())
  owner            User        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  class            Class?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  subject          Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter          Chapter?    @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  parentDeck       FlashcardDeck? @relation("FlashcardDeckTree", fields: [parentDeckId], references: [id], onDelete: SetNull)
  childDecks       FlashcardDeck[] @relation("FlashcardDeckTree")
  sourceResource   Resource?   @relation(fields: [sourceResourceId], references: [id], onDelete: SetNull)
  flashcards       Flashcard[]
  shares           FlashcardShare[]
}

model Flashcard {
  id        String            @id @default(cuid())
  deckId    String
  frontText String
  backText  String
  hintText  String?
  tags      Json?
  position  Int
  createdAt DateTime          @default(now())
  deck      FlashcardDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews   FlashcardReview[]
  states    FlashcardState[]
}

model FlashcardReview {
  id              String          @id @default(cuid())
  flashcardId     String
  userId          String
  rating          FlashcardRating
  reviewedAt      DateTime        @default(now())
  nextReviewAt    DateTime
  stabilityScore  Float?
  difficultyScore Float?
  intervalDays    Float?
  flashcard       Flashcard       @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FlashcardState {
  id              String          @id @default(cuid())
  flashcardId     String
  userId          String
  status          FlashcardStatus
  lastReviewAt    DateTime?
  nextReviewAt    DateTime?
  repetitionCount Int             @default(0)
  lapseCount      Int             @default(0)
  easeScore       Float?
  stabilityScore  Float?
  difficultyScore Float?
  flashcard       Flashcard       @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([flashcardId, userId])
}

model Task {
  id            String         @id @default(cuid())
  studentId     String
  subjectId     String?
  chapterId     String?
  title         String
  description   String?
  taskType      TaskType
  dueAt         DateTime?
  priorityScore Float          @default(0)
  status        String
  sourceType    String
  createdAt     DateTime       @default(now())
  student       User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject?       @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  chapter       Chapter?       @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  sessions      StudySession[]
}

model StudySession {
  id                 String        @id @default(cuid())
  studentId          String
  subjectId          String?
  chapterId          String?
  taskId             String?
  plannedStartAt     DateTime?
  plannedDurationMin Int
  actualDurationMin  Int?
  sessionType        SessionType
  goalText           String
  status             SessionStatus
  difficultyFeedback String?
  usefulnessFeedback String?
  createdByType      String
  createdAt          DateTime      @default(now())
  student            User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject            Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  chapter            Chapter?      @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  task               Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model WeakPoint {
  id             String          @id @default(cuid())
  studentId      String
  subjectId      String
  chapterId      String?
  sourceType     String
  severityScore  Float
  label          String
  description    String?
  status         WeakPointStatus
  lastDetectedAt DateTime
  student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter        Chapter?        @relation(fields: [chapterId], references: [id], onDelete: SetNull)
}

model Essay {
  id             String          @id @default(cuid())
  studentId      String
  teacherId      String?
  subjectId      String
  chapterId      String?
  submissionKey  String?         @unique
  contentHash    String?
  title          String
  examType       String
  targetExam     String
  storageKey     String
  mimeType       String
  submissionType String
  status         EssayStatus
  createdAt      DateTime        @default(now())
  student        User            @relation("StudentEssays", fields: [studentId], references: [id], onDelete: Cascade)
  teacher        User?           @relation("TeacherEssays", fields: [teacherId], references: [id], onDelete: SetNull)
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapter        Chapter?        @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  feedbacks      EssayFeedback[]
}

model GradingRubric {
  id           String          @id @default(cuid())
  creatorId    String
  subjectId    String
  title        String
  description  String?
  criteriaJson Json
  createdAt    DateTime        @default(now())
  creator      User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  subject      Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  feedbacks    EssayFeedback[]
}

model EssayFeedback {
  id             String         @id @default(cuid())
  essayId        String
  submissionKey  String?        @unique
  reviewerType   ReviewerType
  reviewerUserId String?
  rubricId       String?
  scoreMin       Float?
  scoreMax       Float?
  feedbackJson   Json
  createdAt      DateTime       @default(now())
  essay          Essay          @relation(fields: [essayId], references: [id], onDelete: Cascade)
  rubric         GradingRubric? @relation(fields: [rubricId], references: [id], onDelete: SetNull)
}

model AIGeneration {
  id               String   @id @default(cuid())
  userId           String
  featureName      String
  sourceEntityType String
  sourceEntityId   String
  modelName        String
  status           String
  inputSummary     String?
  outputSummary    String?
  costEstimate     Float?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentGrade {
  id         String   @id @default(cuid())
  studentId  String
  subjectId  String
  title      String
  score      Float
  maxScore   Float    @default(20)
  sourceType String
  teacherName String?
  capturedAt DateTime
  createdAt  DateTime @default(now())
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model FlashcardShare {
  id          String        @id @default(cuid())
  ownerUserId String
  rootDeckId  String
  shareCode   String        @unique
  title       String
  payloadJson Json
  createdAt   DateTime      @default(now())
  owner       User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  rootDeck    FlashcardDeck @relation(fields: [rootDeckId], references: [id], onDelete: Cascade)
}

model NewsSelection {
  id           String   @id @default(cuid())
  userId       String
  sectionId    String
  articleUrl   String
  articleTitle String
  sourceName   String
  publishedAt  DateTime?
  selectedAt   DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
